[Unit]
Description=Lasair alert filter process
After=network.target

[Service]
Type=simple
User={{ ansible_user_id }}
WorkingDirectory={{ ansible_env.HOME }}/{{ git_name}}/pipeline/filter
ExecStart={{ venv_path }}/bin/python3 filter_runner.py --grist=alert
Restart=on-failure


[Install]
WantedBy=multi-user.target
